# Configuration for ./docker-compose.yml. Copy to `.env` (gitignored) and run
# from this directory:
#   docker compose up
#
# Walkthrough: ./README.md
# Full server config reference: ../../CONFIGURATION.md

# Optional: published Guardian server image version to run (default: latest).
# GUARDIAN_VERSION=v0.14.9

# Required: password for the bundled Postgres. Set a strong value and keep it
# stable — the Postgres data volume is initialized with it on first run. Use
# only URL-safe characters; it is embedded verbatim in DATABASE_URL.
POSTGRES_PASSWORD=CHANGEME-use-a-strong-password

# Miden network the server targets. This MUST match the "network" field of the
# GUARDIAN_ENDPOINTS entry below, or the dashboard reports the wrong environment.
GUARDIAN_NETWORK_TYPE=MidenTestnet

# Optional: path to your local clone of 0xMiden/guardian-dashboard. Defaults to
# ./guardian-dashboard (a clone inside this guide directory).
# GUARDIAN_DASHBOARD_PATH=./guardian-dashboard

# --- Clerk (human auth for the dashboard) ----------------------------------
# Required: test keys from a free Clerk app (dashboard.clerk.com). The operator
# user's Clerk public metadata must set "role" and an "endpointIds" array that
# includes the endpoint "id" used in GUARDIAN_ENDPOINTS below.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- Guardian connectivity (dashboard -> server) ---------------------------
# Required: JSON array, one entry per Guardian node. Inside the Compose network
# the server is reachable at http://server:3000. "commitment" and "privateKey"
# come from the dashboard's scripts/generate-operator-key.ts (see README step 1);
# the matching public key goes into operators.json. "network" must equal
# GUARDIAN_NETWORK_TYPE above.
GUARDIAN_ENDPOINTS=[{"id":"local","label":"Local Guardian","url":"http://server:3000","network":"MidenTestnet","commitment":"0x...","privateKey":"..."}]
