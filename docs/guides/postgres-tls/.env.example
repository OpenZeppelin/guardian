# Configuration for ./docker-compose.yml. Copy to `.env` (gitignored) and run
# from this directory:
#   ./generate-certs.sh && cp .env.example .env && docker compose up
#
# Walkthrough: ./README.md
# Full server config reference: ../../CONFIGURATION.md

# Required: password for the bundled Postgres. Use only URL-safe characters — it
# is embedded verbatim in DATABASE_URL. The data volume is initialized with it
# on first run, so keep it stable.
POSTGRES_PASSWORD=change-me

# TLS verification level for the server's database connection:
#   verify-full (default) — verify the certificate chain AND that the hostname
#                           matches the cert SAN (the generated cert's SAN is
#                           `postgres`, the Compose service name, so it matches).
#   verify-ca             — verify the chain only (hostname not checked).
# DB_SSLMODE=verify-full

# Optional: published image version to run (default: latest). Use a version that
# includes verified database TLS (this feature) — older images connect without
# verifying the certificate.
# GUARDIAN_VERSION=v1.2.3

# Optional: run a locally built image instead of the published one (e.g. to try
# this before it is released — see "Run against a local build" in README.md).
# Set the pull policy to `missing` so Compose does not try to pull your local tag.
# GUARDIAN_IMAGE=guardian:dbtls-local
# GUARDIAN_PULL_POLICY=missing

# Optional: Miden network the server targets (server default: MidenDevnet).
# GUARDIAN_NETWORK_TYPE=MidenTestnet
