# Configuration for ./docker-compose.yml. Copy to `.env` (gitignored) and run
# from this directory:
#   docker compose up
#
# Walkthrough: ./README.md
# Full server config reference: ../../CONFIGURATION.md

# Required: password for the bundled Postgres. Set a strong value and keep it
# stable — the Postgres data volume is initialized with it on first run. Use
# only URL-safe characters; it is embedded verbatim in DATABASE_URL.
POSTGRES_PASSWORD=change-me

# Required: AWS region holding the Secrets Manager secret and the KMS key.
AWS_REGION=us-east-1

# Required: AWS credentials for the container. Easiest for a single host is to
# export these in your shell before `docker compose up` (e.g. from SSO); Compose
# passes them through. A long-lived host should use an EC2 instance role or
# container credentials instead of static keys — leave these blank then.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Required: Secrets Manager name (or ARN) of the Falcon ACK private key.
# Create it with: ./scripts/aws-deploy.sh bootstrap-ack-keys (with a KMS ARN
# exported, that creates only the Falcon secret).
GUARDIAN_ACK_FALCON_SECRET_ID=guardian/server/ack-falcon-secret-key

# Required: KMS key id, ARN, or alias for the ECDSA ACK signer. The key must be
# ECC_SECG_P256K1 / SIGN_VERIFY. Create it with:
#   ./scripts/aws-deploy.sh bootstrap-kms-ecdsa-key
GUARDIAN_ACK_ECDSA_KMS_KEY_ID=alias/guardian-ack-ecdsa

# Optional: published image version to run (default: latest).
# GUARDIAN_VERSION=v1.2.3

# --- Optional server runtime config (uncomment as needed) ---

# Miden network the server targets (server default: MidenDevnet).
# GUARDIAN_NETWORK_TYPE=MidenTestnet

# Comma-separated origins allowed by credentialed CORS.
# GUARDIAN_CORS_ALLOWED_ORIGINS=https://accounts.openzeppelin.com
