{
  "name": "@openzeppelin/miden-multisig-client",
  "version": "0.1.0",
  "description": "TypeScript SDK for Miden multisig accounts with PSM integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "masm"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openzeppelin/psm-client": "file:../psm-client"
  },
  "peerDependencies": {
    "@demox-labs/miden-sdk": "^0.12.5"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
